@model IEnumerable<BinaDaireYonetim.Models.Bina>

@{
    ViewData["Title"] = "Binalar";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Binalar</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni Bina Ekle
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Bina Adı</th>
                        <th>Adres</th>
                        <th>Kat Sayısı</th>
                        <th>Daire Sayısı</th>
                        <th>İnşaat Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@Html.DisplayFor(modelItem => item.Ad)</strong></td>
                            <td>@Html.DisplayFor(modelItem => item.Adres)</td>
                            <td>@Html.DisplayFor(modelItem => item.KatSayisi)</td>
                            <td>
                                <span class="badge bg-info">@item.Daireler.Count()</span>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.InşaatTarihi, "{0:dd.MM.yyyy}")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> Detay
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Düzenle
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            Henüz bina bulunmamaktadır. <a asp-action="Create">Yeni bina ekleyin</a>
        </div>
    }
</div>