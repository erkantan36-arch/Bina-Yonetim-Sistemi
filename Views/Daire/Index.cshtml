@model IEnumerable<BinaDaireYonetim.Models.Daire>

@{
    ViewData["Title"] = "Daireler";
    int binaId = Convert.ToInt32(ViewData["BinaId"] ?? 0);
    string binaAdi = ViewData["BinaAdi"]?.ToString() ?? "Bilinmeyen Bina";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@binaAdi - Daireler</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" asp-route-binaId="@binaId" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni Daire Ekle
            </a>
            <a asp-controller="Bina" asp-action="Details" asp-route-id="@binaId" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Geri Dön
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>No</th>
                        <th>Tipi</th>
                        <th>Kat</th>
                        <th>Kat Malikleri</th>
                        <th>Kiracılar</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@Html.DisplayFor(modelItem => item.DaireNo)</strong></td>
                            <td>@Html.DisplayFor(modelItem => item.DaireTipi)</td>
                            <td>@Html.DisplayFor(modelItem => item.Kat)</td>
                            <td>
                                @if (item.KatMalikleri?.Any() ?? false)
                                {
                                    <span class="badge bg-success">@item.KatMalikleri.Count()</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Yok</span>
                                }
                            </td>
                            <td>
                                @if (item.Kiracıları?.Any() ?? false)
                                {
                                    <span class="badge bg-success">@item.Kiracıları.Count()</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Yok</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Düzenle
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            Bu binada henüz daire bulunmamaktadır. <a asp-action="Create" asp-route-binaId="@binaId">Yeni daire ekleyin</a>
        </div>
    }
</div>