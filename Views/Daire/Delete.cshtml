@model BinaDaireYonetim.Models.Daire

@{
    ViewData["Title"] = "Daire Sil";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Daire Silme Onayı</h1>
            <hr />

            <div class="alert alert-danger">
                <strong>Uyarı!</strong> Daire No <strong>@Model.DaireNo</strong>'yi silmek istediğinizden emin misiniz?
                <br />
                <small>Bu işlem geri alınamaz!</small>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5>Daire Bilgileri</h5>
                </div>
                <div class="card-body">
                    <p><strong>Daire No:</strong> @Model.DaireNo</p>
                    <p><strong>Daire Tipi:</strong> @Model.DaireTipi</p>
                    <p><strong>Kat:</strong> @Model.Kat</p>
                    <p><strong>Petek Sayısı:</strong> @Model.PetekSayisi</p>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <button type="submit" class="btn btn-danger">Sil</button>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>