<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bina Daire Yönetim</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BinaDaireYonetim.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand { font-weight: 700; font-size: 1.15rem; }
        .sidebar { min-height: calc(100vh - 56px); background: #1a1a2e; }
        .sidebar .nav-link { color: #adb5bd; border-radius: 8px; margin-bottom: 2px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar .nav-link .icon { width: 1.4rem; display: inline-block; text-align: center; }
        .main-content { background: #f4f6fb; min-height: calc(100vh - 56px); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark" style="background:#1a1a2e;">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                🏢 Bina Daire Yönetim
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="text-white-50 small d-none d-sm-inline">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-light">Çıkış</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    <div class="d-flex">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav class="sidebar d-none d-md-block p-3" style="width:220px; flex-shrink:0;">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <span class="icon">📊</span> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bina" ? "active" : "")"
                           asp-controller="Bina" asp-action="Index">
                            <span class="icon">🏢</span> Binalar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Daire" ? "active" : "")"
                           asp-controller="Daire" asp-action="Index">
                            <span class="icon">🚪</span> Daireler
                        </a>
                    </li>
                </ul>
            </nav>
        }

        <div class="main-content flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
